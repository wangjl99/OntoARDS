        <obo:hasExactSynonym xml:lang="en">SCGB1A1</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_biomarker"/>
        <rdfs:label xml:lang="en">Club cell secretory protein 16</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03212 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03212">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Pro-inflammatory cytokine. Elevated in early ARDS; promotes NF-κB and endothelial injury. Elevated in hyperinflammatory subphenotype.</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D014409</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">Cachectin</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">TNF-α</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">TNFa</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_biomarker"/>
        <rdfs:label xml:lang="en">Tumor necrosis factor alpha</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03213 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03213">
        <owl:equivalentClass rdf:resource="http://purl.obolibrary.org/obo/CHEBI_90551"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03214 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03214">
        <owl:equivalentClass rdf:resource="http://snomed.info/id/371907003"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Heated humidified O₂ at 20–60 L/min via wide-bore nasal cannula. FLORALI (PMID 25981908): 90-day mortality 12% vs 23–28% (P=0.02, secondary).</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D000072601</obo:hasDbXref>
        <obo:hasDbXref>SNOMED:371907003</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">HFNC</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">HFNO</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">High-flow nasal oxygen</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Optiflow</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
        <obo:source_pmid>25981908</obo:source_pmid>
        <rdfs:label xml:lang="en">High-flow nasal cannula oxygen therapy</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03215 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03215">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Prone positioning in spontaneously breathing non-intubated patients. PROFLO (PMID 34127046, n=75): null — only 6% achieved ≥16h target.</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D060168</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">Awake proning</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Non-intubated prone positioning</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Self-proning</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
        <obo:source_pmid>34127046</obo:source_pmid>
        <rdfs:label xml:lang="en">Awake prone positioning</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03216 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03216">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03217 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03217">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03218 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03218">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Combined prone+ECMO strategy. PRONECMO (PMID 38038395, n=170, 94% COVID-19): null — prone benefit already captured pre-ECMO in 96% of patients.</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D015199</obo:hasDbXref>
        <obo:hasDbXref>MESH:D060168</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">Prone+ECMO</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Proning on ECMO</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
        <obo:source_pmid>38038395</obo:source_pmid>
        <rdfs:label xml:lang="en">Prone positioning during VV-ECMO</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03219 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03219">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Bedside real-time lung imaging via thoracic electrical impedance. Enables individualised PEEP titration without radiation.</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D017680</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">EIT</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Impedance tomography</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
        <rdfs:label xml:lang="en">Electrical impedance tomography</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03220 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03220">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Oesophageal manometry to measure PL = Paw − Peso. Enables individualised PEEP and P-SILI detection.</obo:IAO_0000115>
        <obo:hasDbXref>SNOMED:229078004</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">Esophageal pressure monitoring</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Oesophageal manometry</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">PL monitoring</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
        <rdfs:label xml:lang="en">Transpulmonary pressure monitoring</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03221 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03221">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <owl:disjointWith rdf:resource="http://poi-kb.org/ards/ARDS_POI_03222"/>
        <obo:IAO_0000115 xml:lang="en">Lung injury from excessive inspiratory effort in spontaneously breathing ARF. Large negative pleural swings increase transpulmonary driving pressure. Explains ACURASYS vs ROSE discordance.</obo:IAO_0000115>
        <obo:hasDbXref>UMLS:C0024115</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">Effort-induced lung injury</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">P-SILI</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Pendelluft injury</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Self-inflicted lung injury</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_mechanism"/>
        <obo:source_pmid>28762180</obo:source_pmid>
        <rdfs:label xml:lang="en">Patient self-inflicted lung injury</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03222 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03222">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <owl:disjointWith rdf:resource="http://poi-kb.org/ards/ARDS_POI_03223"/>
        <obo:IAO_0000115 xml:lang="en">VILI from excessive tidal volume causing alveolar overdistension. Prevented by 6 ml/kg PBW strategy (ARMA, PMID 10793162).</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D055371</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">Alveolar overdistension injury</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Volume-induced lung injury</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_mechanism"/>
        <obo:source_pmid>10793162</obo:source_pmid>
        <rdfs:label xml:lang="en">Volutrauma</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03223 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03223">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">VILI from repetitive cyclic alveolar collapse and re-expansion generating shear stress. Prevented by adequate PEEP.</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D055371</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">Cyclic opening and closing injury</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Shear stress lung injury</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_mechanism"/>
        <rdfs:label xml:lang="en">Atelectrauma</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03224 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03224">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Inflammatory VILI mediated by cytokines (IL-1β, IL-6, IL-8, TNF-α) released from mechanically stressed lung into systemic circulation, linking ventilator injury to distal organ failure.</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D055371</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">VILI-mediated systemic inflammation</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Ventilator-induced biotrauma</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_mechanism"/>
        <rdfs:label xml:lang="en">Biotrauma</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03225 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03225">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">ΔP = Pplat − PEEP. Tidal volume normalised to functional lung size. ΔP &gt;15 cmH₂O independently predicts ARDS mortality (Amato NEJM 2015, PMID 25693014).</obo:IAO_0000115>
        <obo:hasDbXref>LOINC:76221-8</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">Delta P</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Respiratory system driving pressure</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">ΔP</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_outcome"/>
        <obo:source_pmid>25693014</obo:source_pmid>
        <rdfs:label xml:lang="en">Driving pressure</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03226 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03226">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03227 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03227">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Ischemic gut injury from extreme systemic hypoxaemia. LOCO₂ 2020 (PMID 32160661): 5 events with conservative O₂ (PaO₂ 55–70 mmHg) vs 0 in liberal group. Defines lower safety boundary of O₂ conservation.</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D045262</obo:hasDbXref>
        <obo:hasDbXref>UMLS:C0149544</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">Gut ischemia ARDS</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Intestinal ischemia hypoxaemia</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_outcome"/>
        <obo:source_pmid>32160661</obo:source_pmid>
        <rdfs:label xml:lang="en">Mesenteric ischemia in ARDS</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03228 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03228">
        <owl:equivalentClass rdf:resource="http://snomed.info/id/79092005"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Acute cor pulmonale complicating moderate-severe ARDS (~20–25% prevalence). Contraindication to high-PEEP and aggressive recruitment (ART).</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D006333</obo:hasDbXref>
        <obo:hasDbXref>SNOMED:79092005</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">Acute cor pulmonale ARDS</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">RV dysfunction ARDS</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_outcome"/>
        <rdfs:label xml:lang="en">Right ventricular failure in ARDS</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03229 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03229">
        <owl:equivalentClass rdf:resource="http://snomed.info/id/238136002"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">ARDS patients with BMI ≥40 kg/m². Elevated chest wall elastance, reduced FRC. PROBESE enrolled BMI ≥35 (PMID 31157366).</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D009767</obo:hasDbXref>
        <obo:hasDbXref>SNOMED:238136002</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">BMI ≥40 ARDS</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Severely obese ARDS</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_population"/>
        <obo:source_pmid>31157366</obo:source_pmid>
        <rdfs:label xml:lang="en">Morbid obesity ARDS population</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03230 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03230">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03231 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03231">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">ARDS in haematological malignancy, solid organ transplant, HIV, or prolonged corticosteroids. Standard ARDS RCT evidence may not generalise.</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D007153</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">Immunosuppressed ARDS</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_population"/>
        <rdfs:label xml:lang="en">Immunocompromised patient with ARDS</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03232 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03232">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Critical initiation window for ARDS interventions: prone (PROSEVA: &lt;36h), NMB (48h infusion), dexamethasone (within 24h of severity criteria).</obo:IAO_0000115>
        <obo:hasExactSynonym xml:lang="en">Early ARDS window</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">First 48h ARDS</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_context"/>
        <rdfs:label xml:lang="en">First 48 hours ARDS context</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03233 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03233">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">PaO₂/FiO₂ &lt;150 mmHg on PEEP ≥5 cmH₂O for &gt;12–36h. Required for prone benefit (PROSEVA) and VV-ECMO consideration (EOLIA).</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D012128</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">PROSEVA eligibility threshold</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">PaO2/FiO2 &lt;150 ARDS</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_context"/>
        <obo:source_pmid>23688302</obo:source_pmid>
        <rdfs:label xml:lang="en">Severe ARDS context PaO2/FiO2 less than 150</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03234 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03234">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Thoracic surgery requiring OLV: non-ventilated lung atelectasis, V/Q mismatch. iPROVE-OLV (PMID 38065200): individualized OLA beneficial (RR 0.39); contrast iPROVE (abdominal) null.</obo:IAO_0000115>
        <obo:hasDbXref>SNOMED:425389004</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">OLV context</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">One-lung anaesthesia</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_context"/>
        <obo:source_pmid>38065200</obo:source_pmid>
        <rdfs:label xml:lang="en">One-lung ventilation surgical context</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03235 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03235">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Post-2015 ICU practice targeting RASS 0 to −2. Negates apparent NMB benefit seen in ACURASYS (2010, deep sedation era). ROSE (PMID 31112383) confirmed null in this context.</obo:IAO_0000115>
        <obo:hasExactSynonym xml:lang="en">ABCDEF bundle era</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Light sedation practice</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_context"/>
        <obo:source_pmid>31112383</obo:source_pmid>
        <rdfs:label xml:lang="en">Lighter sedation era clinical context</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03260 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03260">
        <owl:equivalentClass rdf:resource="http://snomed.info/id/238136002"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">ARDS patients with BMI ≥40 kg/m². Elevated chest wall elastance and reduced functional residual capacity alter PEEP requirements substantially. Requires individualised PEEP titration. PROBESE trial enrolled BMI ≥35 (PMID 31157366).</obo:IAO_0000115>
        <obo:hasDbXref>MESH:D009767</obo:hasDbXref>
        <obo:hasDbXref>PMID:31157366</obo:hasDbXref>
        <obo:hasDbXref>SNOMED:238136002</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">BMI ≥40 ARDS</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Morbidly obese ARDS patient</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Severely obese ARDS</obo:hasExactSynonym>
        <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_population"/>
        <obo:source_pmid>31157366</obo:source_pmid>
        <rdfs:label xml:lang="en">Morbid obesity in ARDS population</rdfs:label>
    </owl:Class>
    


    <!-- http://poi-kb.org/ards/ARDS_POI_03261 -->

    <owl:Class rdf:about="http://poi-kb.org/ards/ARDS_POI_03261">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">Clinical context defined by PaO₂/FiO₂ &lt;150 mmHg on PEEP ≥5 cmH₂O for &gt;12–36h on mechanical ventilation. Mandatory eligibility threshold for prone positioning benefit (PROSEVA, PMID 23688302) and a key criterion for VV-ECMO consideration (EOLIA, PMID 29791822).</obo:IAO_0000115>
        <obo:hasDbXref>PMID:23688302</obo:hasDbXref>
        <obo:hasDbXref>PMID:29791822</obo:hasDbXref>
        <obo:hasExactSynonym xml:lang="en">PROSEVA eligibility threshold</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">PROSEVA severity threshold PaO2/FiO2 &lt;150</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">PaO2/FiO2 &lt;150 mmHg ARDS context</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Severe ARDS context PaO2/FiO2 &lt;150</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Severe ARDS context PaO₂/FiO₂ &lt;150 mmHg</obo:hasExactSynonym>
        <obo:hasExactSynonym xml:lang="en">Severe ARDS hypoxaemia context</obo:hasExactSynonym>
