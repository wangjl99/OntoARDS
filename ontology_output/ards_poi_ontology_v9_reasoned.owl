<?xml version="1.0"?>
<rdf:RDF xmlns="http://poi-kb.org/ards/ards_poi_ontology#"
     xml:base="http://poi-kb.org/ards/ards_poi_ontology"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:poi="http://poi-kb.org/ards/"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#">
    <owl:Ontology rdf:about="http://poi-kb.org/ards/ards_poi_ontology">
        <dc:creator xml:lang="en">UTHealth Houston School of Biomedical Informatics / MD Anderson Cancer Center</dc:creator>
        <dc:description xml:lang="en">Domain ontology for perioperative ARDS covering interventions, disease subphenotypes, biomarkers, VILI mechanisms, clinical contexts, and outcomes. Part of the NIH R24-funded POI-KB project (1R24HL180372-01). ARDS pilot domain; AKI and liver injury domains in development.</dc:description>
        <dc:source xml:lang="en">https://github.com/poi-kb/ards-ontology</dc:source>
        <dc:title xml:lang="en">POI-KB ARDS Ontology — Perioperative Organ Injury Knowledge Base</dc:title>
        <rdfs:comment xml:lang="en">CQ10: What is the mechanical power threshold (poi:measuredBy EIT) associated with increased ARDS mortality, and which phenotypes are most susceptible?</rdfs:comment>
        <rdfs:comment xml:lang="en">CQ1: Which POI_intervention prevents intubation in hypoinflammatory ARDS with PaO2/FiO2 &lt; 150?</rdfs:comment>
        <rdfs:comment xml:lang="en">CQ2: What biomarkers distinguish hyperinflammatory from hypoinflammatory ARDS subphenotypes?</rdfs:comment>
        <rdfs:comment xml:lang="en">CQ3: Which interventions have differential response by focal vs non-focal ARDS CT morphology?</rdfs:comment>
        <rdfs:comment xml:lang="en">CQ4: List all POI_outcome improved by prone positioning (poi:treats) in severe ARDS (P/F&lt;150).</rdfs:comment>
        <rdfs:comment xml:lang="en">CQ5: What is contraindicated (poi:isContraindicatedIn) in ARDS patients with right ventricular dysfunction?</rdfs:comment>
        <rdfs:comment xml:lang="en">CQ6: Which fluid management strategy prevents pulmonary oedema in conservative management contexts?</rdfs:comment>
        <rdfs:comment xml:lang="en">CQ7: What is the evidence level (sourcePMID, trialAcronym, effectiveWithin) for VV-ECMO in very severe ARDS?</rdfs:comment>
        <rdfs:comment xml:lang="en">CQ8: In hyperinflammatory ARDS, which fluid strategy (poi:hasDifferentialResponse) improves outcomes vs hypoinflammatory?</rdfs:comment>
        <rdfs:comment xml:lang="en">CQ9: Which ARDS CT morphology (focal vs non-focal) shows differential response to prone positioning and high-PEEP strategies?</rdfs:comment>
        <rdfs:comment>Generated from 989 nodes after expert HITL review. Agent 5 BioPortal normalization applied. Agent 6 deduplication (46.8%). Agent 7 consistency 1.000.</rdfs:comment>
        <rdfs:label>POI-KB ARDS Ontology v4 (Expert Reviewed)</rdfs:label>
        <owl:versionInfo>v9 — 2024-2025 literature enhancement</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/IAO_0000115 -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000115"/>
    


    <!-- http://purl.obolibrary.org/obo/hasDbXref -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/hasDbXref"/>
    


    <!-- http://purl.obolibrary.org/obo/hasExactSynonym -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/hasExactSynonym"/>
    


    <!-- http://purl.obolibrary.org/obo/inSubset -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/inSubset"/>
    


    <!-- http://purl.obolibrary.org/obo/source_pmid -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/source_pmid"/>
    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/source -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/source"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://poi-kb.org/ards/activatesPathway -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/activatesPathway">
        <obo:hasDbXref>RO:0002213</obo:hasDbXref>
        <obo:hasDbXref>biolink:positively_regulates</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Entity activates or upregulates the referenced molecular pathway. OBO: RO:0002448 (positively regulates). Corresponds to BioLink biolink:positively_regulates.</rdfs:comment>
        <rdfs:label xml:lang="en">activates pathway</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/affectsOrganSystem -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/affectsOrganSystem">
        <obo:hasDbXref>biolink:affects</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Intervention or disease affects the referenced organ system. OBO: RO:0002206 (expressed in; anatomical context). Corresponds to BioLink biolink:affects.</rdfs:comment>
        <rdfs:label xml:lang="en">affects organ system</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/biologicallyInteractsWith -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/biologicallyInteractsWith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <obo:hasDbXref>RO:0002434</obo:hasDbXref>
        <obo:hasDbXref>biolink:interacts_with</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Symmetric biological interaction between two entities (e.g. alveolar macrophage ↔ type II pneumocyte). OBO: RO:0002434 (interacts with). Corresponds to BioLink biolink:interacts_with.</rdfs:comment>
        <rdfs:label xml:lang="en">biologically interacts with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/causesAdverseOutcome -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/causesAdverseOutcome">
        <obo:hasDbXref>RO:0003303</obo:hasDbXref>
        <obo:hasDbXref>biolink:causes</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Intervention or disease state causally increases the incidence of a harmful outcome. Evidence must be from a controlled trial (not merely observed).  DO-NOT-DO edge in the POI-Graph (e.g. aggressive recruitment → increased mortality, ART trial HR 1.20).  Corresponds to BioLink knowledge graph predicate biolink:causes.</rdfs:comment>
        <rdfs:label xml:lang="en">causes adverse outcome</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/hasAetiology -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/hasAetiology">
        <obo:hasDbXref>RO:0003303</obo:hasDbXref>
        <obo:hasDbXref>biolink:contributes_to</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Disease has a contributing causal factor (aetiology). OBO equivalent: RO:0002410 (causally related to). Corresponds to BioLink biolink:contributes_to (inverse direction).</rdfs:comment>
        <rdfs:label xml:lang="en">has aetiology</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/hasBiomarker -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/hasBiomarker">
        <owl:inverseOf rdf:resource="http://poi-kb.org/ards/isBiomarkerOf"/>
        <obo:hasDbXref>RO:0002559</obo:hasDbXref>
        <obo:hasDbXref>biolink:has_biomarker</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Disease or phenotypic feature has the referenced measurable molecular entity as a biomarker.  OBO: RO:0002488. Corresponds to BioLink biolink:has_biomarker.</rdfs:comment>
        <rdfs:label xml:lang="en">has biomarker</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/hasClinicalOutcome -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/hasClinicalOutcome">
        <obo:hasDbXref>RO:0002558</obo:hasDbXref>
        <obo:hasDbXref>biolink:has_phenotype</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Disease or intervention is associated with the referenced clinical outcome. OBO: RO:0002410. Corresponds to BioLink biolink:has_phenotype.</rdfs:comment>
        <rdfs:label xml:lang="en">has clinical outcome</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/hasDifferentialResponse -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/hasDifferentialResponse">
        <obo:IAO_0000115 xml:lang="en">A relation between an intervention and a disease subphenotype or clinical context indicating that the intervention produces a qualitatively different effect (benefit vs harm vs null) in that subphenotype compared to the overall ARDS population. Key examples: prone positioning in focal vs non-focal ARDS; higher PEEP in hyperinflammatory vs hypoinflammatory subphenotypes.</obo:IAO_0000115>
        <obo:hasDbXref>RO:0002434</obo:hasDbXref>
        <obo:hasDbXref>biolink:related_to</obo:hasDbXref>
        <rdfs:label xml:lang="en">has differential response</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/hasPathophysiology -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/hasPathophysiology">
        <obo:hasDbXref>biolink:related_to</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Disease is associated with the referenced pathophysiological mechanism. OBO equivalent: RO:0002558 (has process). Corresponds to BioLink biolink:related_to.</rdfs:comment>
        <rdfs:label xml:lang="en">has pathophysiology</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/hasRiskFactor -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/hasRiskFactor">
        <obo:hasDbXref>RO:0003303</obo:hasDbXref>
        <obo:hasDbXref>biolink:contributes_to</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Disease has the referenced risk factor contributing to its development. OBO: RO:0002410. Corresponds to BioLink biolink:contributes_to (inverse).</rdfs:comment>
        <rdfs:label xml:lang="en">has risk factor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/hasSeverityStage -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/hasSeverityStage">
        <obo:hasDbXref>biolink:related_to</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Disease has the referenced severity classification (Berlin mild/moderate/severe). OBO: RO:0000091 (has quality).</rdfs:comment>
        <rdfs:label xml:lang="en">has severity stage</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/hasSubphenotype -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/hasSubphenotype">
        <obo:hasDbXref>BFO:0000051</obo:hasDbXref>
        <obo:hasDbXref>biolink:has_part</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Disease has a biologically distinct subphenotype as a part. OBO: RO:0000051 (has part). Corresponds to BioLink biolink:has_part.</rdfs:comment>
        <rdfs:label xml:lang="en">has subphenotype</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/hasTemporalContext -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/hasTemporalContext">
        <obo:hasDbXref>biolink:occurs_in</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Intervention&apos;s apparent effect is modulated by the background practice era (e.g. NMB benefit disappears in the lighter sedation era). Corresponds to BioLink biolink:occurs_in.</rdfs:comment>
        <rdfs:label xml:lang="en">has temporal context</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/improvesPhysiologicParameter -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/improvesPhysiologicParameter">
        <obo:hasDbXref>biolink:ameliorates_condition</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Intervention improves a measurable physiological parameter (e.g. driving pressure, PaO₂/FiO₂) without necessarily improving a clinical outcome. Distinct from poi:treats which requires clinical benefit. Corresponds to BioLink biolink:ameliorates_condition.</rdfs:comment>
        <rdfs:label xml:lang="en">improves physiologic parameter</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/inhibitsPathway -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/inhibitsPathway">
        <obo:hasDbXref>RO:0002212</obo:hasDbXref>
        <obo:hasDbXref>biolink:negatively_regulates</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Entity inhibits or downregulates the referenced molecular pathway. OBO: RO:0002449 (negatively regulates). Corresponds to BioLink biolink:negatively_regulates.</rdfs:comment>
        <rdfs:label xml:lang="en">inhibits pathway</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/isBiomarkerOf -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/isBiomarkerOf">
        <obo:hasDbXref>RO:0002559</obo:hasDbXref>
        <obo:hasDbXref>biolink:biomarker_for</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Molecular entity is a biomarker for the referenced disease. Inverse of poi:hasBiomarker.  OBO: RO:0002488 inverse. Corresponds to BioLink biolink:biomarker_for.</rdfs:comment>
        <rdfs:label xml:lang="en">is biomarker of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/isContraindicatedIn -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/isContraindicatedIn">
        <obo:hasDbXref>biolink:contraindicated_in</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Intervention should not be applied in the referenced patient population or context because it is likely to produce detrimental outcomes. Corresponds to BioLink biolink:contraindicated_in.</rdfs:comment>
        <rdfs:label xml:lang="en">is contraindicated in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/isTreatedBy -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/isTreatedBy">
        <owl:inverseOf rdf:resource="http://poi-kb.org/ards/treats"/>
        <obo:hasDbXref>biolink:treated_by</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Inverse of poi:treats.  Disease is treated by the referenced intervention. Corresponds to BioLink biolink:treated_by.</rdfs:comment>
        <rdfs:label xml:lang="en">is treated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/measuredBy -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/measuredBy">
        <obo:IAO_0000115 xml:lang="en">A relation between an outcome or physiological parameter and the instrument, monitoring modality, or biomarker assay used to measure it. Example: driving pressure measuredBy esophageal manometry; regional ventilation measuredBy EIT.</obo:IAO_0000115>
        <obo:hasDbXref>biolink:related_to</obo:hasDbXref>
        <rdfs:label xml:lang="en">measured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/occursInContext -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/occursInContext">
        <obo:IAO_0000115 xml:lang="en">A relation between an intervention or outcome and a specific clinical practice context that determines its applicability. More specific than poi:requiresClinicalContext — that property encodes mandatory eligibility; this property encodes conditional applicability or era-specific evidence. BioLink: biolink:occurs_in (same xref, distinct semantics).</obo:IAO_0000115>
        <obo:hasDbXref>RO:0001025</obo:hasDbXref>
        <obo:hasDbXref>biolink:occurs_in</obo:hasDbXref>
        <rdfs:label xml:lang="en">occurs in context</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/preventsCondition -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/preventsCondition">
        <rdfs:subPropertyOf rdf:resource="http://poi-kb.org/ards/treats"/>
        <obo:hasDbXref>RO:0002606</obo:hasDbXref>
        <obo:hasDbXref>biolink:prevents</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Intervention delays onset or prevents development of the referenced condition. Subproperty of poi:treats in the OWL hierarchy. Corresponds to BioLink biolink:prevents.</rdfs:comment>
        <rdfs:label xml:lang="en">prevents condition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/progressesTo -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/progressesTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <obo:hasDbXref>RO:0002304</obo:hasDbXref>
        <obo:hasDbXref>biolink:precedes</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Disease or pathological process temporally precedes and causally leads to the referenced state.  Declared as owl:TransitiveProperty. OBO equivalent: RO:0002410. Corresponds to BioLink biolink:precedes.</rdfs:comment>
        <rdfs:label xml:lang="en">progresses to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/requiresClinicalContext -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/requiresClinicalContext">
        <obo:hasDbXref>biolink:occurs_in</obo:hasDbXref>
        <rdfs:comment xml:lang="en">The intervention&apos;s benefit is contingent on the referenced clinical context (e.g. prone positioning requires PaO₂/FiO₂ &lt;150, intubation, early initiation). Corresponds to BioLink biolink:occurs_in.</rdfs:comment>
        <rdfs:label xml:lang="en">requires clinical context</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/temporallyPrecedes -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/temporallyPrecedes">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <obo:hasDbXref>RO:0002304</obo:hasDbXref>
        <obo:hasDbXref>biolink:precedes</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Generic temporal precedence (transitive). OBO: RO:0002501 (temporally related to). Corresponds to BioLink biolink:precedes.</rdfs:comment>
        <rdfs:label xml:lang="en">temporally precedes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/treats -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/treats">
        <obo:hasDbXref>RO:0002606</obo:hasDbXref>
        <obo:hasDbXref>biolink:treats</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Holds between a therapeutic intervention and a disease or clinical outcome it ameliorates, stabilises, or cures.  Use only when the intervention showed statistically significant clinical benefit in the primary or pre-specified secondary outcome (RCT or high-quality systematic review). Provenance: RO:0002606 (is substance that treats); corresponds to BioLink knowledge graph predicate biolink:treats.</rdfs:comment>
        <rdfs:label xml:lang="en">treats</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://poi-kb.org/ards/worsensClinicalParameter -->

    <owl:ObjectProperty rdf:about="http://poi-kb.org/ards/worsensClinicalParameter">
        <obo:hasDbXref>biolink:disrupts</obo:hasDbXref>
        <rdfs:comment xml:lang="en">Intervention or disease worsens a physiological or clinical parameter. Corresponds to BioLink biolink:disrupts.</rdfs:comment>
        <rdfs:label xml:lang="en">worsens clinical parameter</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://poi-kb.org/ards/crossoverRate -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/crossoverRate">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Proportion (%) of control patients crossing over to intervention arm.</rdfs:comment>
        <rdfs:label xml:lang="en">crossover rate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/earlyStoppingReason -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/earlyStoppingReason">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reason for early termination: efficacy | futility | safety | enrollment | NA.</rdfs:comment>
        <rdfs:label xml:lang="en">early stopping reason</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/effectiveWithin -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/effectiveWithin">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Time window for beneficial effect: &apos;first 48h&apos;, &apos;within 36h&apos;, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">effective within</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/has95CILower -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/has95CILower">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Lower bound of 95% confidence interval.</rdfs:comment>
        <rdfs:label xml:lang="en">has 95% CI lower bound</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/has95CIUpper -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/has95CIUpper">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Upper bound of 95% confidence interval.</rdfs:comment>
        <rdfs:label xml:lang="en">has 95% CI upper bound</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/hasAbsoluteRiskDifference -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/hasAbsoluteRiskDifference">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Absolute risk difference (%). Negative = favours intervention.</rdfs:comment>
        <rdfs:label xml:lang="en">has absolute risk difference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/hasEvidenceLevel -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/hasEvidenceLevel">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">OCEBM evidence level: 1a | 1b | 2a | 2b | 3 | 4 | 5.</rdfs:comment>
        <rdfs:label xml:lang="en">has evidence level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/hasGRADERecommendation -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/hasGRADERecommendation">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">GRADE: strong-for | conditional-for | conditional-against | strong-against.</rdfs:comment>
        <rdfs:label xml:lang="en">has GRADE recommendation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/hasHazardRatio -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/hasHazardRatio">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Hazard ratio from time-to-event analysis. Values &lt;1 favour intervention.</rdfs:comment>
        <rdfs:label xml:lang="en">has hazard ratio</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/hasNumberNeededToTreat -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/hasNumberNeededToTreat">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Patients needed to treat to prevent one additional adverse outcome.</rdfs:comment>
        <rdfs:label xml:lang="en">has number needed to treat</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/hasPValue -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/hasPValue">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Two-sided p-value for the primary outcome comparison.</rdfs:comment>
        <rdfs:label xml:lang="en">has p-value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/hasRelativeRiskReduction -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/hasRelativeRiskReduction">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Relative risk reduction (%) for the primary outcome. Positive = benefit.</rdfs:comment>
        <rdfs:label xml:lang="en">has relative risk reduction</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/mechanismClarity -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/mechanismClarity">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Confidence in proposed mechanism: ESTABLISHED | PROPOSED | UNKNOWN.</rdfs:comment>
        <rdfs:label xml:lang="en">mechanism clarity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/sampleSize -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/sampleSize">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Number of patients enrolled in the trial.</rdfs:comment>
        <rdfs:label xml:lang="en">sample size</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/sourcePMID -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/sourcePMID">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">PubMed identifier of the primary supporting publication.</rdfs:comment>
        <rdfs:label xml:lang="en">source PMID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/sourcePMIDCount -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/sourcePMIDCount">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Total number of supporting PubMed records.</rdfs:comment>
        <rdfs:label xml:lang="en">source PMID count</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/temporalContext -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/temporalContext">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Practice era context: pre-COVID | COVID-era | deep-sedation-era | lighter-sedation-era | pre-RECOVERY.</rdfs:comment>
        <rdfs:label xml:lang="en">temporal context</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/trialAcronym -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/trialAcronym">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Trial identifier (e.g. ARMA, PROSEVA, ART, ROSE, DEXA-ARDS, EOLIA).</rdfs:comment>
        <rdfs:label xml:lang="en">trial acronym</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://poi-kb.org/ards/trialYear -->

    <owl:DatatypeProperty rdf:about="http://poi-kb.org/ards/trialYear">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Year of primary trial publication.</rdfs:comment>
        <rdfs:label xml:lang="en">trial year</rdfs:label>
    </owl:DatatypeProperty>
    


